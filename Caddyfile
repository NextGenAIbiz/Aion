# Aion — Local HTTPS reverse proxy
# ─────────────────────────────────────────────────────────────────────────────
# Problem: GitHub Pages is HTTPS. Your LLM API at http://10.161.112.104:3000
#          is HTTP. Browsers block mixed-content requests — so we proxy.
#
# How it works:
#   Browser (GitHub Pages HTTPS)
#     └─► https://localhost:9443/v1   (Caddy, trusted local cert)
#           └─► http://10.161.112.104:3000/v1   (your LLM server)
#
# Setup (run once on the machine you use to browse):
#   1. winget install Caddy.Caddy
#   2. caddy trust                        ← installs local CA (browser trusts it)
#   3. caddy run --config Caddyfile       ← start proxy
#
# In Aion Settings, set Endpoint URL to:  https://localhost:9443/v1
# ─────────────────────────────────────────────────────────────────────────────

{
    # Use Caddy's built-in local CA for localhost certs (trusted after `caddy trust`)
    local_certs
}

localhost:9443 {
    tls internal

    # ── Forward to your LLM API server ───────────────────────────────────────
    reverse_proxy http://10.161.112.104:3000 {
        header_up Host {upstream_hostport}
    }

    # ── CORS — allow calls from any origin (GitHub Pages, local, etc.) ────────
    header {
        Access-Control-Allow-Origin  *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
    }

    @options method OPTIONS
    respond @options 204
}
